    """Handles all inline button clicks."""
    query = update.callback_query
    await query.answer() # Acknowledge the button click
    
    data = query.data

    if data == 'menu_signals':
        text = (
            "📈 Signals Service\n\n"
            "✔️ High accuracy signals\n"
            "✔️ Forex, Gold & Crypto\n"
            "✔️ Daily setups\n\n"
            "💰 Price: $50/month\n\n"
            "👇 Choose:"
        )
        keyboard = [
            [InlineKeyboardButton("Buy Now", callback_data='payment')],
            [InlineKeyboardButton("Back", callback_data='main_menu')]
        ]
        await query.edit_message_text(text=text, reply_markup=InlineKeyboardMarkup(keyboard))

    elif data == 'menu_account':
        text = (
            "💼 Account Management\n\n"
            "✔️ We trade for you\n"
            "✔️ Risk management\n"
            "✔️ Weekly profit target\n\n"
            "💰 Minimum Investment: $100\n\n"
            "👇 Choose:"
        )
        keyboard = [
            [InlineKeyboardButton("Start Now", callback_data='payment')],
            [InlineKeyboardButton("Back", callback_data='main_menu')]
        ]
        await query.edit_message_text(text=text, reply_markup=InlineKeyboardMarkup(keyboard))

    elif data == 'menu_vip':
        text = (
            "💎 VIP Access\n\n"
            "✔️ Premium signals\n"
            "✔️ Fast updates\n"
            "✔️ Private support\n\n"
            "💰 Price: $100/month\n\n"
            "👇 Choose:"
        )
        keyboard = [
            [InlineKeyboardButton("Get VIP", callback_data='payment')],
            [InlineKeyboardButton("Back", callback_data='main_menu')]
        ]
        await query.edit_message_text(text=text, reply_markup=InlineKeyboardMarkup(keyboard))

    elif data == 'payment':
        text = (
            "💳 Payment Method:\n\n"
            "Send payment via Binance / USDT\n\n"
            "📩 After payment, send screenshot here or contact:\n"
            "@Ali_Trades01\n"
            "@Ali_Trades02"
        )
        keyboard = [
            [InlineKeyboardButton("Back to Main Menu", callback_data='main_menu')]
        ]
        await query.edit_message_text(text=text, reply_markup=InlineKeyboardMarkup(keyboard))

    elif data == 'main_menu':
        # Route back to the start function to display the main menu
        await start(update, context)


async def fallback_message(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    """Handles any standard text input from the user."""
    await update.message.reply_text("Please use the buttons to navigate.")


def main() -> None:
    """Builds and runs the bot."""
    if BOT_TOKEN == "YOUR_BOT_TOKEN_HERE":
        print("❌ ERROR: Please replace 'YOUR_BOT_TOKEN_HERE' with your actual bot token!")
        return

    # Create the application using the bot token
    application = ApplicationBuilder().token(BOT_TOKEN).build()

    # Add Handlers
    application.add_handler(CommandHandler("start", start))
    application.add_handler(CallbackQueryHandler(button_handler))
    
    # Filter for standard text messages (excluding commands) to trigger the fallback
    application.add_handler(MessageHandler(filters.TEXT & ~filters.COMMAND, fallback_message))

    # Start the Bot using Polling
    print("🤖 Bot is running... Press Ctrl+C to stop.")
    application.run_polling()

if __name__ == '__main__':
    main()
