import logging
from telegram import Update, InlineKeyboardButton, InlineKeyboardMarkup
from telegram.ext import (
    ApplicationBuilder,
    CommandHandler,
    CallbackQueryHandler,
    MessageHandler,
    filters,
    ContextTypes
)

# Enable logging to help debug if something goes wrong
logging.basicConfig(
    format='%(asctime)s - %(name)s - %(levelname)s - %(message)s',
    level=logging.INFO
)
logger = logging.getLogger(__name__)

# --- Replace this with your actual Bot Token from @BotFather ---
BOT_TOKEN = "YOUR_BOT_TOKEN_HERE"


async def start(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    """Handles the /start command and displays the main menu."""
    
    welcome_text = (
        "🤖 Welcome to Umar Trades Pro Bot 🚀\n\n"
        "📊 تريد النجاح في التداول؟\n"
        "Join professional trading services using SMC, ICT & Price Action.\n\n"
        "💼 Our Services:\n"
        "📈 Signals\n"
        "💼 Account Management\n"
        "💎 VIP Access\n\n"
        "👇 Choose an option below:"
    )

    # Define the inline keyboard layout
    keyboard = [
        [InlineKeyboardButton("📈 Signals", callback_data='menu_signals')],
        [InlineKeyboardButton("💼 Account Management", callback_data='menu_account')],
        [InlineKeyboardButton("💎 VIP Access", callback_data='menu_vip')]
    ]
    reply_markup = InlineKeyboardMarkup(keyboard)

    # If triggered by a message (/start)
    if update.message:
        await update.message.reply_text(welcome_text, reply_markup=reply_markup)
    # If triggered by a callback (Back button returning to main menu)
    elif update.callback_query:
        await update.callback_query.edit_message_text(welcome_text, reply_markup=reply_markup)


